{
	"allowNonWorkspaceAccess": true,
	"altScreenMode": "always",
	"artifactReviewPolicy": "agent-decides",
	"enableTelemetry": false,
	"enableTerminalSandbox": true,
	"model": "Gemini 3.5 Flash (High)",
	"notifications": true,
	"permissions": {
		"allow": [
			"unsandboxed(gh)",
			"unsandboxed(mkdir)",
			"unsandboxed(git status)",
			"unsandboxed(git diff)",
			"unsandboxed(git log)",
			"unsandboxed(find)",
			"unsandboxed(bats)",
			"unsandboxed(git add)",
			"mcp(github/list_issues)",
			"unsandboxed(git show)",
			"unsandboxed(git clone)",
			"unsandboxed(cp)",
			"unsandboxed(ls)",
			"unsandboxed(touch)",
			"unsandboxed(xattr)",
			"unsandboxed(ps)",
			"unsandboxed(grep)",
			"unsandboxed(mv)",
			"unsandboxed(bun run)",
			"unsandboxed(bunx)",
			"mcp(github/list_pull_requests)",
			"mcp(github/get_pull_request_status)",
			"mcp(github/get_pull_request_comments)",
			"unsandboxed(~/.gemini/skills/autoreview/scripts/autoreview)",
			"unsandboxed(tail)",
			"unsandboxed(cd)",
			"unsandboxed(bun add)",
			"mcp(github/list_commits)",
			"mcp(github/get_pull_request_files)",
			"unsandboxed(echo)",
			"unsandboxed(git branch)",
			"unsandboxed(react-doctor)",
			"unsandboxed(sleep)",
			"unsandboxed(head)",
			"unsandboxed(wc)",
			"unsandboxed(cat)",
			"unsandboxed(bun biome)",
			"unsandboxed(npx)",
			"unsandboxed(yarn install)",
			"unsandboxed(kubectl get)",
			"unsandboxed(kubectl logs)",
			"unsandboxed(kubectl exec)",
			"unsandboxed(kubectl run)",
			"unsandboxed(export)",
			"unsandboxed(kubectl describe)",
			"unsandboxed(git remote)",
			"mcp(github/create_issue)",
			"mcp(github/search_issues)",
			"unsandboxed(git fetch)",
			"unsandboxed(bash)",
			"unsandboxed(helm)",
			"unsandboxed(mktemp)",
			"unsandboxed(cat)",
			"unsandboxed(chmod)",
			"unsandboxed(yarn)",
			"unsandboxed(curl)",
			"unsandboxed(go test)",
			"unsandboxed(gofmt)",
			"unsandboxed(npx tsc)",
			"unsandboxed(go vet)",
			"unsandboxed(gh api)",
			"unsandboxed(node)",
			"unsandboxed(python3)"
		],
		"deny": ["command(git reset --hard)", "command(git push --force)", "command(rm -rf)"]
	},
	"runningLightSpeed": "off",
	"showFeedbackSurvey": false,
	"showTips": false,
	"statusLine": {
		"type": "command",
		"command": "bash ~/.gemini/antigravity-cli/statusline.sh",
		"enabled": true
	},
	"toolPermission": "proceed-in-sandbox"
}
