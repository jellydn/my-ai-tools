{
  "allowNonWorkspaceAccess": true,
  "artifactReviewPolicy": "agent-decides",
  "enableTelemetry": false,
  "enableTerminalSandbox": true,
  "model": "Claude Opus 4.6 (Thinking)",
  "notifications": true,
  "permissions": {
    "allow": [
      "unsandboxed(gh)",
      "unsandboxed(mkdir)",
      "unsandboxed(git status)",
      "unsandboxed(git diff)",
      "unsandboxed(git log)",
      "unsandboxed(find)",
      "unsandboxed(bats)",
      "unsandboxed(git add)",
      "mcp(github/list_issues)",
      "unsandboxed(git show)",
      "unsandboxed(git clone)",
      "unsandboxed(cp)",
      "unsandboxed(ls)",
      "unsandboxed(touch)",
      "unsandboxed(xattr)",
      "unsandboxed(ps)",
      "unsandboxed(grep)",
      "unsandboxed(mv)",
      "unsandboxed(bun run)",
      "unsandboxed(bunx)",
      "mcp(github/list_pull_requests)",
      "mcp(github/get_pull_request_status)",
      "mcp(github/get_pull_request_comments)"
    ],
    "deny": [
      "command(git reset --hard)",
      "command(git push --force)",
      "command(rm -rf)"
    ]
  },
  "runningLightSpeed": "off",
  "showFeedbackSurvey": false,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.gemini/antigravity-cli/statusline.sh",
    "enabled": true
  },
  "toolPermission": "proceed-in-sandbox",
  "trustedWorkspaces": [],
  "verbosity": "low"
}
