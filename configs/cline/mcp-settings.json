{
	"mcpServers": {
		"context7": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@latest"]
		},
		"sequential-thinking": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
		},
		"qmd": {
			"alwaysAllow": [],
			"command": "qmd",
			"args": ["mcp"]
		},
		"fff": {
			"alwaysAllow": [],
			"command": "fff-mcp",
			"args": []
		},
		"react-grab-mcp": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@react-grab/mcp", "--stdio"]
		},
		"logpilot": {
			"alwaysAllow": [],
			"command": "logpilot",
			"args": ["mcp-server"]
		},
		"agentmemory": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@agentmemory/mcp"]
		},
		"user-memory": {
			"alwaysAllow": [],
			"command": "user-memory-mcp",
			"args": []
		},
		"sem": {
			"alwaysAllow": [],
			"command": "sem-mcp",
			"args": []
		},
		"ctx": {
			"alwaysAllow": [],
			"command": "ctx",
			"args": ["mcp", "serve"]
		},
		"codebase-memory-mcp": {
			"command": "codebase-memory-mcp",
			"args": [],
			"alwaysAllow": []
		}
	}
