{
	"mcpServers": {
		"context7": {
			"alwaysAllow": [],
			"url": "https://mcp.context7.com/mcp"
		},
		"sequential-thinking": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
		},
		"qmd": {
			"alwaysAllow": [],
			"command": "qmd",
			"args": ["mcp"]
		},
		"fff": {
			"alwaysAllow": [],
			"command": "fff-mcp",
			"args": []
		},
		"react-grab-mcp": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@react-grab/mcp", "--stdio"]
		},
		"logpilot": {
			"alwaysAllow": [],
			"command": "logpilot",
			"args": ["mcp-server"]
		},
		"agentmemory": {
			"alwaysAllow": [],
			"command": "npx",
			"args": ["-y", "@agentmemory/mcp"]
		},
		"sem": {
			"type": "local",
			"command": "sem-mcp",
			"args": [],
			"env": {},
			"tools": ["*"]
		}
	}
}
