{
	"mcpServers": {
		"context7": {
			"type": "local",
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp@latest"],
			"env": {},
			"tools": ["*"]
		},
		"sequential-thinking": {
			"type": "local",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
			"env": {},
			"tools": ["*"]
		},
		"fff": {
			"type": "local",
			"command": "fff-mcp",
			"args": [],
			"env": {},
			"tools": ["*"]
		},
		"qmd": {
			"type": "local",
			"command": "qmd",
			"args": ["mcp"],
			"env": {},
			"tools": ["*"]
		},
		"chrome-devtools": {
			"type": "local",
			"command": "npx",
			"args": ["-y", "chrome-devtools-mcp@latest"],
			"env": {},
			"tools": ["*"]
		},
		"react-grab-mcp": {
			"type": "local",
			"command": "npx",
			"args": ["-y", "@react-grab/mcp", "--stdio"],
			"env": {},
			"tools": ["*"]
		},
		"logpilot": {
			"type": "local",
			"command": "logpilot",
			"args": ["mcp-server"],
			"env": {},
			"tools": ["*"]
		}
	}
}
