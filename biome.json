{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 1,
		"lineWidth": 120
	},
	"linter": {
		"enabled": false
	},
	"javascript": {
		"formatter": {
			"indentStyle": "tab",
			"indentWidth": 1,
			"quoteStyle": "double"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"indentWidth": 1
		}
	}
}
